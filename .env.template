# HowToSoftware — Environment Variables
# Copy this file to .env and fill in the values.
#   cp .env.template .env

# ── Database ────────────────────────────────────────────────
# SA password for SQL Server (min 8 chars, upper+lower+digit+symbol)
DB_SA_PASSWORD=

# ── Site ────────────────────────────────────────────────────
# Public URL including scheme (used by Caddy, app links, Open Graph, etc.)
SITE_URL=https://howtoosoftware.com

# ── Email (Mailgun) ────────────────────────────────────────
MAILGUN_DOMAIN=
MAILGUN_API_KEY=
# Optional: explicit SMTP login. Leave blank to use postmaster@${MAILGUN_DOMAIN}.
# Set this if you created a custom SMTP credential in Mailgun.
MAILGUN_SMTP_USERNAME=

            <div class="nav-item">
                <NavLink href="recommendations">
                    <i class="bi bi-hand-thumbs-up-fill"></i> Recommendations
                </NavLink>
            </div>
        </AuthorizeView>

        <AuthorizeView Roles="Owner,Administrator">
            <div class="nav-heading">Settings</div>

            <div class="nav-item">
                <NavLink href="settings">
                    <i class="bi bi-gear-fill"></i> General

            </div>
        </AuthorizeView>

        <AuthorizeView Roles="Owner,Administrator">
            <div class="nav-item">
                <NavLink href="analytics">
                    <i class="bi bi-graph-up"></i> Analytics
                </NavLink>
            </div>
        </AuthorizeView>

        <AuthorizeView Roles="Owner,Administrator">
            <div class="nav-heading">Members</div>

            <div class="nav-item">
                <NavLink href="members">
                    <i class="bi bi-people-fill"></i> Members
                </NavLink>
            </div>

            <div class="nav-item">
                <NavLink href="newsletters">
                    <i class="bi bi-envelope-fill"></i> Newsletters
                </NavLink>
            </div>

            <div class="nav-item">
                <NavLink href="automated-emails">
                    <i class="bi bi-lightning-fill"></i> Automated Emails
                </NavLink>
            </div>

            <div class="nav-item">

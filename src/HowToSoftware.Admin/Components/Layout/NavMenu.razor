    <div class="sidebar-footer">
        <AuthorizeView>
            <div class="user-info">
                <i class="bi bi-person-circle"></i>
                <span>@context.User.FindFirst(ClaimTypes.Name)?.Value</span>
            </div>
            <a href="/account/logout" class="sign-out">
                <i class="bi bi-box-arrow-left"></i> Sign out
            </a>
        </AuthorizeView>
    </div>
</div>

@code {
    private int pendingMentionCount;

    protected override async Task OnInitializedAsync()
    {
        // Use an isolated DI scope so the badge query gets its own AppDbContext.
        // The shared per-circuit scoped DbContext is being used concurrently by
        // the page component's OnInitializedAsync, which would otherwise trigger
        // "A second operation was started on this context instance".
        // Failures (e.g. DB blip) must not break the sidebar — every page renders
        // this component.
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var mentionService = scope.ServiceProvider.GetRequiredService<IMentionService>();
            pendingMentionCount = await mentionService.GetPendingCountAsync();
        }
        catch
        {
            pendingMentionCount = 0;
        }
    }
}


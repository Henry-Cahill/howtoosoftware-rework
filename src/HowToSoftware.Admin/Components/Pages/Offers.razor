@page "/offers"
@using HowToSoftware.Core.Entities
@using HowToSoftware.Core.Interfaces
@attribute [Authorize(Roles = "Owner,Administrator")]
@inject IOfferService OfferService
@rendermode InteractiveServer

<PageTitle>Offers — HowToSoftware Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Offers</h1>
    <a href="offers/new" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New offer</a>
</div>

@if (offers is null)
{
    <p class="text-muted">Loading…</p>
}
else if (offers.Count == 0)
{
    <div class="card">
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-ticket-perforated display-4 d-block mb-2"></i>
            No offers yet. Create one to offer discounts on your tiers.
        </div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Code</th>
                    <th>Tier</th>
                    <th>Discount</th>
                    <th>Duration</th>
                    <th>Redemptions</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var offer in offers)
                {
                    <tr class="@(offer.Active ? "" : "opacity-50")">
                        <td>@offer.Name</td>
                        <td><code>@offer.Code</code></td>
                        <td>@(offer.Product?.Name ?? "—")</td>
                        <td>@FormatDiscount(offer)</td>
                        <td>@FormatDuration(offer)</td>
                        <td>@offer.Redemptions.Count</td>
                        <td>
                            @if (offer.Active)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Archived</span>
                            }
                        </td>
                        <td>
                            <a href="offers/@offer.Id/edit" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil me-1"></i>Edit
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Offer>? offers;

    protected override async Task OnInitializedAsync()
    {
        offers = await OfferService.GetOffersAsync();
    }

    private static string FormatDiscount(Offer offer)
    {
        if (offer.DiscountType == "percent")
            return $"{offer.DiscountAmount}% off";

        var symbol = (offer.Currency?.ToUpperInvariant()) switch
        {
            "USD" or null => "$",
            "EUR" => "€",
            "GBP" => "£",
            _ => offer.Currency?.ToUpperInvariant() + " ",
        };
        return $"{symbol}{offer.DiscountAmount / 100m:F2} off";
    }

    private static string FormatDuration(Offer offer)
    {
        return offer.Duration switch
        {
            "once" => "First payment",
            "forever" => "Forever",
            "repeating" when offer.DurationInMonths.HasValue =>
                $"{offer.DurationInMonths} month{(offer.DurationInMonths > 1 ? "s" : "")}",
            _ => offer.Duration,
        };
    }
}


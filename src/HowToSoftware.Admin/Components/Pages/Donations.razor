@page "/donations"
@using HowToSoftware.Core.Entities
@using HowToSoftware.Core.Interfaces
@attribute [Authorize(Roles = "Owner,Administrator")]
@inject IDonationService DonationService
@rendermode InteractiveServer

<PageTitle>Donations — HowToSoftware Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Donations</h1>
</div>

<!-- Settings Card -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Donation Settings</h5>
        @if (!editingSettings)
        {
            <button class="btn btn-sm btn-outline-primary" @onclick="StartEditSettings">
                <i class="bi bi-pencil me-1"></i>Edit
            </button>
        }
    </div>
    <div class="card-body">
        @if (editingSettings)
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Currency</label>
                    <select class="form-select" @bind="editCurrency">
                        <option value="USD">USD ($)</option>
                        <option value="EUR">EUR (€)</option>
                        <option value="GBP">GBP (£)</option>
                        <option value="CAD">CAD (C$)</option>
                        <option value="AUD">AUD (A$)</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Suggested amount (cents)</label>
                    <input type="number" class="form-control" @bind="editSuggestedAmount" min="100" step="100" />
                    <div class="form-text">@FormatAmount(editSuggestedAmount, editCurrency)</div>
                </div>
                <div class="col-12">
                    <button class="btn btn-primary me-2" @onclick="SaveSettings" disabled="@saving">
                        @(saving ? "Saving…" : "Save")
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="CancelEditSettings">Cancel</button>
                </div>
            </div>
        }
        else if (settings is not null)
        {
            <div class="row">
                <div class="col-md-4">
                    <strong>Currency:</strong> @settings.Currency
                </div>
                <div class="col-md-4">
                    <strong>Suggested amount:</strong> @FormatAmount(settings.SuggestedAmountInCents, settings.Currency)
                </div>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">Loading…</p>
        }
    </div>
</div>

<!-- Donations List -->
<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Donation History</h5>
    </div>
    @if (donations is null)
    {
        <div class="card-body">
            <p class="text-muted mb-0">Loading…</p>
        </div>
    }
    else if (donations.Count == 0)
    {
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-heart display-4 d-block mb-2"></i>
            No donations received yet.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Donor</th>
                        <th>Email</th>
                        <th>Amount</th>
                        <th>Message</th>
                        <th>Member</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in donations)
                    {
                        <tr>
                            <td>@d.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(d.Name ?? "—")</td>
                            <td>@d.Email</td>
                            <td>@FormatAmount(d.Amount, d.Currency)</td>
                            <td>@(d.DonationMessage ?? "—")</td>
                            <td>
                                @if (d.Member is not null)
                                {
                                    <span class="badge bg-info">@d.Member.Email</span>
                                }
                                else
                                {
                                    <span class="text-muted">Guest</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer text-muted">
            @donations.Count donation@(donations.Count != 1 ? "s" : "") —
            Total: @FormatAmount(donations.Sum(d => d.Amount), settings?.Currency ?? "USD")
        </div>
    }
</div>

@code {
    private DonationSettings? settings;
    private List<DonationPaymentEvent>? donations;

    private bool editingSettings;
    private bool saving;
    private string editCurrency = "USD";
    private int editSuggestedAmount = 500;

    protected override async Task OnInitializedAsync()
    {
        settings = await DonationService.GetSettingsAsync();
        donations = await DonationService.GetDonationsAsync();
    }

    private void StartEditSettings()
    {
        if (settings is null) return;
        editCurrency = settings.Currency;
        editSuggestedAmount = settings.SuggestedAmountInCents;
        editingSettings = true;
    }

    private void CancelEditSettings()
    {
        editingSettings = false;
    }

    private async Task SaveSettings()
    {
        saving = true;
        try
        {
            var updated = new DonationSettings
            {
                Currency = editCurrency,
                SuggestedAmountInCents = editSuggestedAmount,
            };
            await DonationService.UpdateSettingsAsync(updated);
            settings = updated;
            editingSettings = false;
        }
        finally
        {
            saving = false;
        }
    }

    private static string FormatAmount(int amountInCents, string currency)
    {
        var symbol = currency.ToUpperInvariant() switch
        {
            "USD" => "$",
            "EUR" => "€",
            "GBP" => "£",
            "CAD" => "C$",
            "AUD" => "A$",
            _ => currency.ToUpperInvariant() + " ",
        };
        return $"{symbol}{amountInCents / 100m:F2}";
    }
}


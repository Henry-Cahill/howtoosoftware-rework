    private async Task ViewRevisionAsync(PostRevision rev)
    {
        selectedRevision = rev;
        selectedRevisionId = rev.Id;
        revisionPreviewHtml = !string.IsNullOrEmpty(rev.Lexical) ? LexicalRenderer.Render(rev.Lexical) : null;
        showRevisionPreview = true;
        await Task.CompletedTask;
    }

    private void ConfirmRestoreRevision(PostRevision rev)
    {
        revisionToRestore = rev;
        showRestoreConfirm = true;
    }

    private async Task RestoreRevisionAsync()
    {
        if (revisionToRestore is null || IsNew) return;
        saving = true;
        statusMessage = null;
        showRestoreConfirm = false;
        showRevisionPreview = false;
        try
        {
            post = await ContentService.RestoreRevisionAsync(PostId!, revisionToRestore.Id, userId);
            LoadPostIntoForm(post);

            // Reload editor content with restored Lexical
            if (editorModule is not null && post.Lexical is not null)
            {
                await editorModule.InvokeVoidAsync("destroy");
                await editorModule.InvokeVoidAsync("init", editorWrapperRef, dotNetRef, post.Lexical);
            }

            isDirty = false;
            statusMessage = "Revision restored";
            revisions = null; // Force reload on next open
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            saving = false;
            revisionToRestore = null;
            selectedRevisionId = null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (autosaveTimer is not null)
        {
            await autosaveTimer.DisposeAsync();
        }
        if (editorModule is not null)
        {
            try { await editorModule.InvokeVoidAsync("destroy"); } catch { }
            await editorModule.DisposeAsync();
        }
        dotNetRef?.Dispose();
    }

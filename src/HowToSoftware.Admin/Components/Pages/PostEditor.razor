    private async Task UploadFeatureImageAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > 10 * 1024 * 1024)
        {
            statusMessage = "Image must be under 10 MB";
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var result = await ImageStorage.UploadAsync(stream, file.Name, file.ContentType);
            featureImage = result.Url;
            isDirty = true;
        }
        catch (Exception ex)
        {
            statusMessage = $"Upload failed: {ex.Message}";
        }
    }

    private void RemoveFeatureImage()
    {
        featureImage = null;
        isDirty = true;
    }

    // ── Tag tokenized input ─────────────────────────────────────

    private void OnTagSearchChanged()
    {
        var query = tagSearchText.Trim();
        if (string.IsNullOrEmpty(query))
        {
            filteredTags = allTags
                .Where(t => !selectedTagIds.Contains(t.Id))
                .Take(10)
                .ToList();
        }
        else
        {
            filteredTags = allTags
                .Where(t => !selectedTagIds.Contains(t.Id)
                    && t.Name.Contains(query, StringComparison.OrdinalIgnoreCase))
                .Take(10)
                .ToList();
        }
        highlightedTagId = filteredTags.FirstOrDefault()?.Id;
        showTagDropdown = true;
    }

    private void OnTagInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Backspace" && string.IsNullOrEmpty(tagSearchText) && selectedTagIds.Count > 0)
        {
            selectedTagIds.RemoveAt(selectedTagIds.Count - 1);
            isDirty = true;
        }
        else if (e.Key == "Enter")
        {
            if (highlightedTagId is not null)
            {
                var tag = filteredTags.FirstOrDefault(t => t.Id == highlightedTagId);
                if (tag is not null)
                    SelectTag(tag);
            }
            else if (!string.IsNullOrWhiteSpace(tagSearchText) && filteredTags.Count == 0)
            {
                _ = InvokeAsync(CreateAndSelectTagAsync);
            }
        }
        else if (e.Key == "ArrowDown" && filteredTags.Count > 0)
        {
            var idx = filteredTags.FindIndex(t => t.Id == highlightedTagId);
            idx = Math.Min(idx + 1, filteredTags.Count - 1);
            highlightedTagId = filteredTags[idx].Id;
        }
        else if (e.Key == "ArrowUp" && filteredTags.Count > 0)
        {
            var idx = filteredTags.FindIndex(t => t.Id == highlightedTagId);
            idx = Math.Max(idx - 1, 0);
            highlightedTagId = filteredTags[idx].Id;
        }
        else if (e.Key == "Escape")
        {
            showTagDropdown = false;
        }
    }

    private void OnTagInputBlur()
    {
        // Delay to allow mousedown on dropdown items to fire first
        _ = InvokeAsync(async () =>
        {
            await Task.Delay(150);
            showTagDropdown = false;
            StateHasChanged();
        });
    }

    private void SelectTag(Tag tag)
    {
        if (!selectedTagIds.Contains(tag.Id))
        {
            selectedTagIds.Add(tag.Id);
            isDirty = true;
        }
        tagSearchText = "";
        filteredTags = [];
        showTagDropdown = false;
    }

    private void RemoveTag(string tagId)
    {
        selectedTagIds.Remove(tagId);
        isDirty = true;
    }

    private async Task CreateAndSelectTagAsync()
    {
        var name = tagSearchText.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;

        var slug = await SlugGenerator.GenerateUniqueSlugAsync(
            name,
            async s => await TagRepository.GetBySlugAsync(s) is not null);

        var tag = new Tag
        {
            Id = GenerateTagId(),
            Name = name,
            Slug = slug,
            Visibility = "public",
            CreatedAt = DateTime.UtcNow,
        };
        await TagRepository.AddAsync(tag);
        allTags.Add(tag);
        allTags = [.. allTags.OrderBy(t => t.Name)];
        SelectTag(tag);
    }

    private static string GenerateTagId()
    {
        Span<byte> bytes = stackalloc byte[12];
        System.Security.Cryptography.RandomNumberGenerator.Fill(bytes);
        return Convert.ToHexString(bytes).ToLowerInvariant();
    }

    private static string StatusBadgeClass(string status) => status switch
    {
        "published" => "bg-success",
        "draft" => "bg-secondary",
        "scheduled" => "bg-info text-dark",
        _ => "bg-secondary",
    };

    private static string RevisionReasonClass(string? reason) => reason switch
    {
        "initial" => "bg-info",
        "published" => "bg-success",
        "scheduled" => "bg-info",
        "restored" => "bg-warning text-dark",
        "autosave" => "bg-secondary",
        _ => "bg-secondary",
    };

    private async Task ToggleRevisionHistoryAsync()
    {
        showRevisionHistory = !showRevisionHistory;
        if (showRevisionHistory && revisions is null && !IsNew)
        {
            await LoadRevisionsAsync();
        }
    }


@page "/settings"
@using System.Text.Json
@using HowToSoftware.Core.Interfaces
@attribute [Authorize(Roles = "Owner,Administrator")]
@inject ISettingsService SettingsService
@inject IImageStorageService ImageStorage
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Settings — HowToSoftware Admin</PageTitle>

<!-- Top Bar -->
<div class="editor-topbar">
    <div class="d-flex align-items-center gap-2">
        <h1 class="h4 mb-0">Settings</h1>
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <span class="@(isError ? "text-danger" : "text-success") small">
                <i class="bi @(isError ? "bi-exclamation-circle" : "bi-check-circle") me-1"></i>@statusMessage
            </span>
        }
    </div>
    <div class="d-flex align-items-center gap-2">
        <button class="btn btn-sm btn-primary" @onclick="SaveAsync" disabled="@saving">
            @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
            <i class="bi bi-check-lg me-1"></i>Save
        </button>
    </div>
</div>

@if (!loaded)
{
    <p class="text-muted">Loading…</p>
}
else
{
    <!-- General -->
    <div class="card mb-4">
        <div class="card-header">
            <h6 class="mb-0"><i class="bi bi-globe me-2"></i>General</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Site title</label>
                    <input type="text" class="form-control" @bind="title" placeholder="My Site" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Site description</label>
                    <input type="text" class="form-control" @bind="description"
                           placeholder="Thoughts, stories and ideas." />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Timezone</label>
                    <select class="form-select" @bind="timezone">
                        @foreach (var tz in timezones)
                        {
                            <option value="@tz.Id">@tz.DisplayName</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Language / Locale</label>
                    <input type="text" class="form-control" @bind="locale" placeholder="en" />
                    <div class="form-text">Default locale used for your publication (e.g. en, es, fr)</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Accent color</label>
                    <div class="input-group" style="max-width: 260px">
                        <input type="color" class="form-control form-control-color"
                               value="@(accentColor ?? "#FF1A75")"
                               @onchange="e => accentColor = e.Value?.ToString()" />
                        <input type="text" class="form-control" @bind="accentColor" placeholder="#FF1A75" />
                        @if (!string.IsNullOrEmpty(accentColor))
                        {
                            <button class="btn btn-outline-secondary" @onclick="() => accentColor = null">
                                <i class="bi bi-x"></i>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Branding: Logo, Icon, Cover Image -->
    <div class="card mb-4">
        <div class="card-header">
            <h6 class="mb-0"><i class="bi bi-palette me-2"></i>Branding</h6>
        </div>
        <div class="card-body">
            <div class="row g-4">
                <!-- Logo -->
                <div class="col-md-4">
                    <label class="form-label">Publication logo</label>
                    @if (!string.IsNullOrEmpty(logo))
                    {
                        <div class="branding-preview">
                            <img src="@logo" alt="Logo" />
                            <button class="btn btn-sm btn-danger branding-remove" @onclick="() => logo = null">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    }
                    else
                    {
                        <label class="feature-image-upload">
                            <InputFile OnChange="e => UploadImageAsync(e, v => logo = v)" accept="image/*" />
                            <i class="bi bi-image me-2"></i>Upload logo
                        </label>
                    }
                </div>

                <!-- Icon -->
                <div class="col-md-4">
                    <label class="form-label">Publication icon</label>
                    <div class="form-text mb-2">Square image, at least 60×60px</div>
                    @if (!string.IsNullOrEmpty(icon))
                    {
                        <div class="branding-preview">
                            <img src="@icon" alt="Icon" class="icon-preview" />
                            <button class="btn btn-sm btn-danger branding-remove" @onclick="() => icon = null">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    }
                    else
                    {
                        <label class="feature-image-upload">
                            <InputFile OnChange="e => UploadImageAsync(e, v => icon = v)" accept="image/*" />
                            <i class="bi bi-image me-2"></i>Upload icon
                        </label>
                    }
                </div>

                <!-- Cover Image -->
                <div class="col-md-4">
                    <label class="form-label">Publication cover</label>
                    @if (!string.IsNullOrEmpty(coverImage))
                    {
                        <div class="branding-preview">
                            <img src="@coverImage" alt="Cover" />
                            <button class="btn btn-sm btn-danger branding-remove" @onclick="() => coverImage = null">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    }
                    else
                    {
                        <label class="feature-image-upload">
                            <InputFile OnChange="e => UploadImageAsync(e, v => coverImage = v)" accept="image/*" />
                            <i class="bi bi-image me-2"></i>Upload cover
                        </label>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Social Links -->
    <div class="card mb-4">
        <div class="card-header">
            <h6 class="mb-0"><i class="bi bi-share me-2"></i>Social accounts</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Facebook</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-facebook"></i></span>
                        <input type="text" class="form-control" @bind="facebook"
                               placeholder="facebook.com/page" />
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label">X (Twitter)</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-twitter-x"></i></span>
                        <input type="text" class="form-control" @bind="twitter"
                               placeholder="@@username" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Navigation -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="bi bi-signpost-split me-2"></i>Navigation</h6>
        </div>
        <div class="card-body">
            <!-- Primary Navigation -->
            <h6 class="small text-muted text-uppercase mb-2">Primary navigation</h6>
            @for (var i = 0; i < primaryNav.Count; i++)
            {
                var index = i;
                <div class="d-flex gap-2 mb-2 align-items-center">
                    <input type="text" class="form-control form-control-sm" style="max-width: 200px"
                           value="@primaryNav[index].Label"
                           @onchange="e => SetNavLabel(primaryNav, index, e)" placeholder="Label" />
                    <input type="text" class="form-control form-control-sm"
                           value="@primaryNav[index].Url"
                           @onchange="e => SetNavUrl(primaryNav, index, e)" placeholder="/" />
                    <button class="btn btn-sm btn-outline-danger flex-shrink-0" @onclick="() => primaryNav.RemoveAt(index)">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            }
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => primaryNav.Add(new NavItem())">
                <i class="bi bi-plus-lg me-1"></i>Add item
            </button>

            <hr class="my-3" />

            <!-- Secondary Navigation -->
            <h6 class="small text-muted text-uppercase mb-2">Secondary navigation</h6>
            @for (var i = 0; i < secondaryNav.Count; i++)
            {
                var index = i;
                <div class="d-flex gap-2 mb-2 align-items-center">
                    <input type="text" class="form-control form-control-sm" style="max-width: 200px"
                           value="@secondaryNav[index].Label"
                           @onchange="e => SetNavLabel(secondaryNav, index, e)" placeholder="Label" />
                    <input type="text" class="form-control form-control-sm"
                           value="@secondaryNav[index].Url"
                           @onchange="e => SetNavUrl(secondaryNav, index, e)" placeholder="/" />
                    <button class="btn btn-sm btn-outline-danger flex-shrink-0" @onclick="() => secondaryNav.RemoveAt(index)">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            }
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => secondaryNav.Add(new NavItem())">
                <i class="bi bi-plus-lg me-1"></i>Add item
            </button>
        </div>
    </div>

    <!-- Meta Data -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="bi bi-search me-2"></i>Meta data</h6>
            <button class="btn btn-sm btn-link text-muted p-0 text-decoration-none"
                    @onclick="() => showMeta = !showMeta">
                <i class="bi @(showMeta ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </button>
        </div>
        @if (showMeta)
        {
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small">Meta title</label>
                        <input type="text" class="form-control form-control-sm" @bind="metaTitle" placeholder="Site meta title" />
                        <div class="form-text">Recommended: 60 characters. @(metaTitle?.Length ?? 0)/60</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">Meta description</label>
                        <textarea class="form-control form-control-sm" rows="2" @bind="metaDescription"
                                  placeholder="Search engine description…"></textarea>
                        <div class="form-text">Recommended: 160 characters. @(metaDescription?.Length ?? 0)/160</div>
                    </div>
                </div>

                <!-- Facebook / OG -->
                <div class="border-top pt-3 mt-3">
                    <small class="text-muted fw-semibold">Facebook card</small>
                </div>
                <div class="row g-3 mt-1">
                    <div class="col-md-6">
                        <label class="form-label small">OG title</label>
                        <input type="text" class="form-control form-control-sm" @bind="ogTitle" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">OG description</label>
                        <textarea class="form-control form-control-sm" rows="2" @bind="ogDescription"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">OG image</label>
                        @if (!string.IsNullOrEmpty(ogImage))
                        {
                            <div class="d-flex align-items-center gap-2">
                                <img src="@ogImage" alt="OG image" style="max-height: 60px; border-radius: 4px" />
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ogImage = null">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                        }
                        else
                        {
                            <InputFile OnChange="e => UploadImageAsync(e, v => ogImage = v)" accept="image/*"
                                       class="form-control form-control-sm" />
                        }
                    </div>
                </div>

                <!-- Twitter -->
                <div class="border-top pt-3 mt-3">
                    <small class="text-muted fw-semibold">X (Twitter) card</small>
                </div>
                <div class="row g-3 mt-1">
                    <div class="col-md-6">
                        <label class="form-label small">Twitter title</label>
                        <input type="text" class="form-control form-control-sm" @bind="twitterTitle" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">Twitter description</label>
                        <textarea class="form-control form-control-sm" rows="2" @bind="twitterDescription"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">Twitter image</label>
                        @if (!string.IsNullOrEmpty(twitterImage))
                        {
                            <div class="d-flex align-items-center gap-2">
                                <img src="@twitterImage" alt="Twitter image" style="max-height: 60px; border-radius: 4px" />
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => twitterImage = null">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                        }
                        else
                        {
                            <InputFile OnChange="e => UploadImageAsync(e, v => twitterImage = v)" accept="image/*"
                                       class="form-control form-control-sm" />
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Code Injection -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="bi bi-code-slash me-2"></i>Code injection</h6>
            <button class="btn btn-sm btn-link text-muted p-0 text-decoration-none"
                    @onclick="() => showCodeInjection = !showCodeInjection">
                <i class="bi @(showCodeInjection ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </button>
        </div>
        @if (showCodeInjection)
        {
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label small">Site header</label>
                    <textarea class="form-control form-control-sm font-monospace" rows="6"
                              @bind="codeinjectionHead"
                              placeholder="&lt;!-- Injected into &lt;head&gt; on every page --&gt;"></textarea>
                </div>
                <div class="mb-0">
                    <label class="form-label small">Site footer</label>
                    <textarea class="form-control form-control-sm font-monospace" rows="6"
                              @bind="codeinjectionFoot"
                              placeholder="&lt;!-- Injected before &lt;/body&gt; on every page --&gt;"></textarea>
                </div>
            </div>
        }
    </div>
}

@code {
    // State
    private bool loaded;
    private bool saving;
    private bool showMeta;
    private bool showCodeInjection;
    private string? statusMessage;
    private bool isError;

    // General
    private string title = "";
    private string description = "";
    private string? accentColor;
    private string timezone = "Etc/UTC";
    private string locale = "en";

    // Branding
    private string? logo;
    private string? icon;
    private string? coverImage;

    // Social
    private string? facebook;
    private string? twitter;

    // Navigation
    private List<NavItem> primaryNav = [];
    private List<NavItem> secondaryNav = [];

    // Meta
    private string? metaTitle;
    private string? metaDescription;
    private string? ogTitle;
    private string? ogDescription;
    private string? ogImage;
    private string? twitterTitle;
    private string? twitterDescription;
    private string? twitterImage;

    // Code injection
    private string? codeinjectionHead;
    private string? codeinjectionFoot;

    // Timezone list
    private readonly IReadOnlyCollection<TimeZoneInfo> timezones = TimeZoneInfo.GetSystemTimeZones();

    // JSON options for navigation serialization
    private static readonly JsonSerializerOptions JsonOpts = new() { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAsync();
        loaded = true;
    }

    private async Task LoadSettingsAsync()
    {
        // General
        title = await SettingsService.GetStringAsync("title") ?? "";
        description = await SettingsService.GetStringAsync("description") ?? "";
        accentColor = await SettingsService.GetStringAsync("accent_color");
        timezone = await SettingsService.GetStringAsync("timezone") ?? "Etc/UTC";
        locale = await SettingsService.GetStringAsync("locale") ?? "en";

        // Branding
        logo = await SettingsService.GetStringAsync("logo");
        icon = await SettingsService.GetStringAsync("icon");
        coverImage = await SettingsService.GetStringAsync("cover_image");

        // Social
        facebook = await SettingsService.GetStringAsync("facebook");
        twitter = await SettingsService.GetStringAsync("twitter");

        // Navigation
        primaryNav = await SettingsService.GetJsonAsync<List<NavItem>>("navigation") ?? [new NavItem { Label = "Home", Url = "/" }];
        secondaryNav = await SettingsService.GetJsonAsync<List<NavItem>>("secondary_navigation") ?? [];

        // Meta
        metaTitle = await SettingsService.GetStringAsync("meta_title");
        metaDescription = await SettingsService.GetStringAsync("meta_description");
        ogTitle = await SettingsService.GetStringAsync("og_title");
        ogDescription = await SettingsService.GetStringAsync("og_description");
        ogImage = await SettingsService.GetStringAsync("og_image");
        twitterTitle = await SettingsService.GetStringAsync("twitter_title");
        twitterDescription = await SettingsService.GetStringAsync("twitter_description");
        twitterImage = await SettingsService.GetStringAsync("twitter_image");

        // Code injection
        codeinjectionHead = await SettingsService.GetStringAsync("codeinjection_head");
        codeinjectionFoot = await SettingsService.GetStringAsync("codeinjection_foot");
    }

    private async Task SaveAsync()
    {
        statusMessage = null;
        isError = false;
        saving = true;

        try
        {
            // General
            await SettingsService.SetAsync("title", title.Trim());
            await SettingsService.SetAsync("description", description.Trim());
            await SettingsService.SetAsync("accent_color", TrimOrNull(accentColor));
            await SettingsService.SetAsync("timezone", timezone);
            await SettingsService.SetAsync("locale", locale.Trim());

            // Branding
            await SettingsService.SetAsync("logo", logo);
            await SettingsService.SetAsync("icon", icon);
            await SettingsService.SetAsync("cover_image", coverImage);

            // Social
            await SettingsService.SetAsync("facebook", TrimOrNull(facebook));
            await SettingsService.SetAsync("twitter", TrimOrNull(twitter));

            // Navigation — serialize cleaned items (skip empty entries)
            var cleanPrimary = primaryNav
                .Where(n => !string.IsNullOrWhiteSpace(n.Label) || !string.IsNullOrWhiteSpace(n.Url))
                .ToList();
            var cleanSecondary = secondaryNav
                .Where(n => !string.IsNullOrWhiteSpace(n.Label) || !string.IsNullOrWhiteSpace(n.Url))
                .ToList();
            await SettingsService.SetAsync("navigation", JsonSerializer.Serialize(cleanPrimary, JsonOpts));
            await SettingsService.SetAsync("secondary_navigation", JsonSerializer.Serialize(cleanSecondary, JsonOpts));

            // Meta
            await SettingsService.SetAsync("meta_title", TrimOrNull(metaTitle));
            await SettingsService.SetAsync("meta_description", TrimOrNull(metaDescription));
            await SettingsService.SetAsync("og_title", TrimOrNull(ogTitle));
            await SettingsService.SetAsync("og_description", TrimOrNull(ogDescription));
            await SettingsService.SetAsync("og_image", ogImage);
            await SettingsService.SetAsync("twitter_title", TrimOrNull(twitterTitle));
            await SettingsService.SetAsync("twitter_description", TrimOrNull(twitterDescription));
            await SettingsService.SetAsync("twitter_image", twitterImage);

            // Code injection
            await SettingsService.SetAsync("codeinjection_head", TrimOrNull(codeinjectionHead));
            await SettingsService.SetAsync("codeinjection_foot", TrimOrNull(codeinjectionFoot));

            SettingsService.InvalidateCache();
            statusMessage = "Settings saved!";
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
            isError = true;
        }
        finally
        {
            saving = false;
        }
    }

    private async Task UploadImageAsync(InputFileChangeEventArgs e, Action<string> setter)
    {
        var file = e.File;
        if (file.Size > 10 * 1024 * 1024)
        {
            statusMessage = "Image must be under 10 MB.";
            isError = true;
            return;
        }
        using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        var result = await ImageStorage.UploadAsync(stream, file.Name, file.ContentType);
        setter(result.Url);
    }

    private static void SetNavLabel(List<NavItem> list, int index, ChangeEventArgs e)
        => list[index].Label = e.Value?.ToString() ?? "";

    private static void SetNavUrl(List<NavItem> list, int index, ChangeEventArgs e)
        => list[index].Url = e.Value?.ToString() ?? "";

    private static string? TrimOrNull(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed class NavItem
    {
        [System.Text.Json.Serialization.JsonPropertyName("label")]
        public string Label { get; set; } = "";

        [System.Text.Json.Serialization.JsonPropertyName("url")]
        public string Url { get; set; } = "";
    }
}


    private static string FormatRelative(DateTime utc)
    {
        var delta = DateTime.UtcNow - utc;
        if (delta.TotalSeconds < 0) return utc.ToLocalTime().ToString("MMM d, yyyy");
        if (delta.TotalMinutes < 1) return "just now";
        if (delta.TotalMinutes < 60) return $"{(int)delta.TotalMinutes}m ago";
        if (delta.TotalHours < 24) return $"{(int)delta.TotalHours}h ago";
        if (delta.TotalDays < 7) return $"{(int)delta.TotalDays}d ago";
        if (delta.TotalDays < 30) return $"{(int)(delta.TotalDays / 7)}w ago";
        return utc.ToLocalTime().ToString("MMM d, yyyy");
    }

    private async Task ViewAsMemberAsync()
    {
        if (member is null || impersonating) return;
        impersonating = true;
        statusMessage = null;
        isError = false;
        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var user = auth.User;
            var adminUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            var adminUserEmail = user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;

            if (string.IsNullOrEmpty(adminUserId))
            {
                statusMessage = "Could not determine the signed-in admin user.";
                isError = true;
                return;
            }

            var rawToken = await Impersonation.CreateTokenAsync(member.Id, adminUserId, adminUserEmail);

            await AdminAudit.LogAsync(new AdminAuditEntry
            {
                AdminUserId = adminUserId,
                AdminUserEmail = adminUserEmail,
                Action = "member.impersonate.token_issued",
                TargetType = "member",
                TargetId = member.Id,
                Metadata = $"{{\"memberEmail\":\"{member.Email}\"}}",
            });

            var siteUrl = (await Settings.GetStringAsync("url") ?? "").TrimEnd('/');
            if (string.IsNullOrEmpty(siteUrl))
            {
                // Fall back to the admin's own origin (strip the /ghost path base).
                var baseUri = new Uri(Navigation.BaseUri);
                siteUrl = $"{baseUri.Scheme}://{baseUri.Authority}";
            }

            var verifyUrl = $"{siteUrl}/api/member/impersonate/verify?token={Uri.EscapeDataString(rawToken)}";
            await JS.InvokeVoidAsync("open", verifyUrl, "_blank", "noopener");

            statusMessage = "Opened impersonation session in a new tab. The session expires in 30 minutes.";
        }
        catch (Exception ex)
        {
            statusMessage = $"Could not start impersonation: {ex.Message}";
            isError = true;
        }
        finally
        {
            impersonating = false;
        }
    }

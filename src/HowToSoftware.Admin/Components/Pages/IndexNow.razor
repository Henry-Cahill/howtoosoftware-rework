@page "/indexnow"
@using HowToSoftware.Core.Interfaces
@attribute [Authorize(Roles = "Owner,Administrator")]
@inject ISettingsService SettingsService
@rendermode InteractiveServer

<PageTitle>IndexNow — HowToSoftware Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">IndexNow</h1>
</div>

@if (!loaded)
{
    <p class="text-muted">Loading…</p>
}
else
{
    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @(statusIsError ? "alert-danger" : "alert-success") alert-dismissible fade show" role="alert">
            @statusMessage
            <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <p class="text-muted mb-3">
                <a href="https://www.indexnow.org" target="_blank" rel="noopener noreferrer">IndexNow</a>
                instantly notifies search engines (Bing, Yandex, and others) when posts or pages are published or updated.
            </p>

            <div class="mb-3">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="indexNowEnabled" @bind="enabled" />
                    <label class="form-check-label" for="indexNowEnabled">
                        Enable IndexNow notifications
                    </label>
                </div>
            </div>

            <div class="mb-3">
                <label for="siteUrl" class="form-label">Site URL</label>
                <input type="url" class="form-control" id="siteUrl" @bind="siteUrl"
                       placeholder="https://howtoosoftware.com" />
                <div class="form-text">The public URL of your site (used to build full URLs for IndexNow submissions).</div>
            </div>

            <div class="mb-3">
                <label for="apiKey" class="form-label">API Key</label>
                <div class="input-group">
                    <input type="text" class="form-control font-monospace" id="apiKey" @bind="apiKey"
                           placeholder="e.g. a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4" />
                    <button class="btn btn-outline-secondary" type="button" @onclick="GenerateApiKey">
                        <i class="bi bi-arrow-clockwise me-1"></i>Generate
                    </button>
                </div>
                <div class="form-text">
                    A hex string (32 chars recommended). This key must also be verifiable at
                    <code>@(string.IsNullOrEmpty(siteUrl) ? "https://yoursite.com" : siteUrl.TrimEnd('/'))/@(string.IsNullOrEmpty(apiKey) ? "{key}" : apiKey).txt</code>
                    — the Web project serves this automatically.
                </div>
            </div>

            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@saving">
                @if (saving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                <i class="bi bi-check-lg me-1"></i>Save
            </button>
        </div>
    </div>

    <div class="card">
        <div class="card-header">How it works</div>
        <div class="card-body">
            <ol class="mb-0">
                <li>Enable IndexNow and set your site URL and API key above.</li>
                <li>When you publish or update a post/page, the URL is automatically submitted to search engines.</li>
                <li>Search engines verify your key by requesting <code>/{apiKey}.txt</code> from your site.</li>
                <li>URLs are batched (up to 100) and submitted to <code>api.indexnow.org</code>.</li>
            </ol>
        </div>
    </div>
}

@code {
    private bool loaded;
    private bool enabled;
    private string siteUrl = "";
    private string apiKey = "";
    private bool saving;
    private string? statusMessage;
    private bool statusIsError;

    protected override async Task OnInitializedAsync()
    {
        enabled = await SettingsService.GetBoolAsync("indexnow_enabled") == true;
        siteUrl = await SettingsService.GetStringAsync("indexnow_site_url") ?? "";
        apiKey = await SettingsService.GetStringAsync("indexnow_api_key") ?? "";
        loaded = true;
    }

    private void GenerateApiKey()
    {
        apiKey = Guid.NewGuid().ToString("N");
    }

    private async Task SaveAsync()
    {
        saving = true;
        statusMessage = null;

        try
        {
            await SettingsService.SetBoolAsync("indexnow_enabled", enabled);
            await SettingsService.SetAsync("indexnow_site_url", siteUrl.TrimEnd('/'));
            await SettingsService.SetAsync("indexnow_api_key", apiKey.Trim());
            SettingsService.InvalidateCache();

            statusMessage = "IndexNow settings saved.";
            statusIsError = false;
        }
        catch (Exception ex)
        {
            statusMessage = $"Failed to save: {ex.Message}";
            statusIsError = true;
        }
        finally
        {
            saving = false;
        }
    }
}


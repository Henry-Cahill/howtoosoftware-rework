    private async Task ConnectHubAsync()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/hubs/analytics"))
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<AnalyticsDashboardPayload>("ReceiveDashboard", async payload =>
            {
                kpi = payload.Kpi;
                topPages = payload.TopPages;
                topSources = payload.TopSources;
                devices = payload.Devices;
                browsers = payload.Browsers;
                operatingSystems = payload.OperatingSystems;
                referrers = payload.Referrers;
                countries = payload.Countries;
                trafficTimeSeries = payload.TrafficTimeSeries;
                utmCampaigns = payload.UtmCampaigns;
                searchTerms = payload.SearchTerms;
                postEngagement = payload.PostEngagement;
                memberEngagement = payload.MemberEngagement;
                loading = false;
                await LoadComparisonAsync();
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<List<MemberPostActivityRow>>("ReceiveMemberPostActivity", async activity =>
            {
                memberPostActivity = activity;
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<int>("ReceiveLiveVisitors", async count =>
            {
                liveVisitors = count;
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<List<RecentPageviewDto>>("ReceiveRecentPageviews", async pageviews =>
            {
                recentPageviews = pageviews;
                await InvokeAsync(StateHasChanged);
            });

            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(5));
            await hubConnection.StartAsync(cts.Token);
        }
        catch (Exception)
        {
            // Hub connection is optional — real-time updates won't work but page still functions
        }
    }

    private async Task ExportCsvAsync()
    {
        if (exporting) return;
        exporting = true;
        StateHasChanged();
        try
        {
            var sb = new StringBuilder();
            var rangeLabel = $"{dateFrom:yyyy-MM-dd} to {dateTo.AddDays(-1):yyyy-MM-dd}";
            sb.Append("HowToSoftware Analytics Export").Append('\n');
            sb.Append("Date range,").Append(CsvEscape(rangeLabel)).Append('\n');
            sb.Append("Generated,").Append(DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss")).Append(" UTC\n");
            sb.Append('\n');

            // KPIs
            sb.Append("# KPIs\n");
            sb.Append("metric,value\n");
            if (kpi is not null)
            {
                sb.Append("Unique Visitors,").Append(kpi.Visitors).Append('\n');
                sb.Append("Visits,").Append(kpi.Visits).Append('\n');
                sb.Append("Pageviews,").Append(kpi.Pageviews).Append('\n');
                sb.Append("Bounce Rate %,").Append(kpi.BounceRatePercent.ToString("0.##")).Append('\n');
                sb.Append("Avg Session Duration (s),").Append(kpi.AvgSessionDurationSeconds.ToString("0.##")).Append('\n');
            }
            sb.Append('\n');

            // Top Pages
            sb.Append("# Top Pages\n");
            sb.Append("page_path,post_title,author,published_at,pageviews,unique_visitors,avg_time_on_page_seconds\n");
            if (topPages is not null)
            {
                foreach (var p in topPages)
                {
                    sb.Append(CsvEscape(p.PagePath)).Append(',');
                    sb.Append(CsvEscape(p.PostTitle ?? "")).Append(',');
                    sb.Append(CsvEscape(p.AuthorName ?? "")).Append(',');
                    sb.Append(p.PublishedAt is { } pub ? pub.ToString("yyyy-MM-dd") : "").Append(',');
                    sb.Append(p.Pageviews).Append(',');
                    sb.Append(p.UniqueVisitors).Append(',');
                    sb.Append(p.AvgTimeOnPageSeconds?.ToString("0.##") ?? "").Append('\n');
                }
            }
            sb.Append('\n');

            // Top Sources
            sb.Append("# Top Sources\n");
            sb.Append("source,visits,unique_visitors\n");
            if (topSources is not null)
            {
                foreach (var s in topSources)
                {
                    sb.Append(CsvEscape(s.Source)).Append(',');
                    sb.Append(s.Visits).Append(',');
                    sb.Append(s.UniqueVisitors).Append('\n');
                }
            }
            sb.Append('\n');

            // Search Terms
            sb.Append("# Search Terms\n");
            sb.Append("term,engine,visits,unique_visitors\n");
            if (searchTerms is not null)
            {
                foreach (var st in searchTerms)
                {
                    sb.Append(CsvEscape(st.Term)).Append(',');
                    sb.Append(CsvEscape(st.Engine)).Append(',');
                    sb.Append(st.Visits).Append(',');
                    sb.Append(st.UniqueVisitors).Append('\n');
                }
            }
            sb.Append('\n');

            // Countries
            sb.Append("# Countries\n");
            sb.Append("country,visitors,percentage\n");
            if (countries is not null)
            {
                foreach (var c in countries)
                {
                    sb.Append(CsvEscape(c.Country)).Append(',');
                    sb.Append(c.Visitors).Append(',');
                    sb.Append(c.Percentage.ToString("0.##")).Append('\n');
                }
            }

            var bytes = Encoding.UTF8.GetBytes(sb.ToString());
            var base64 = Convert.ToBase64String(bytes);
            var filename = $"analytics-{dateFrom:yyyyMMdd}-{dateTo.AddDays(-1):yyyyMMdd}.csv";
            await JS.InvokeVoidAsync("downloadCsv", filename, base64);
        }
        catch (Exception ex)
        {
            errorMessage = $"Export failed: {ex.Message}";
        }
        finally
        {
            exporting = false;
            StateHasChanged();
        }
    }

    private static string CsvEscape(string value)
    {
        if (value.Contains(',') || value.Contains('"') || value.Contains('\n') || value.Contains('\r'))
            return $"\"{value.Replace("\"", "\"\"")}\"";
        return value;
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await JS.InvokeVoidAsync("analyticsCharts.destroyAll");
            try { await JS.InvokeVoidAsync("analyticsMap.destroy"); } catch { /* ignore */ }
            await hubConnection.DisposeAsync();
        }
    }


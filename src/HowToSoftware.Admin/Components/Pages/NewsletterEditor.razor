                Navigation.NavigateTo("newsletters");
                return;
            }
            LoadNewsletterIntoForm(newsletter);
            subscriberCount = await NewsletterRepository.GetSubscriberCountAsync(newsletter.Id);
        }
        loaded = true;
    }


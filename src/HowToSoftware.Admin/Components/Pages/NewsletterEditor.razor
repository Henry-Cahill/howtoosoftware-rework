@page "/newsletters/new"
@page "/newsletters/{NewsletterId}/edit"
@using HowToSoftware.Core.Entities
@using HowToSoftware.Core.Interfaces
@using System.Security.Claims
@attribute [Authorize(Roles = "Owner,Administrator")]
@inject INewsletterRepository NewsletterRepository
@inject ISlugGenerator SlugGenerator
@inject ISettingsService SettingsService
@inject IEmailService EmailService
@inject IImageStorageService ImageStorage
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>@(IsNew ? "New Newsletter" : $"Edit Newsletter — {name}") — HowToSoftware Admin</PageTitle>

<!-- Top Bar -->
<div class="editor-topbar">
    <div class="d-flex align-items-center gap-2">
        <a href="newsletters" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Newsletters
        </a>
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <span class="@(isError ? "text-danger" : "text-success") small">
                <i class="bi @(isError ? "bi-exclamation-circle" : "bi-check-circle") me-1"></i>@statusMessage
            </span>
        }
    </div>
    <div class="d-flex align-items-center gap-2">
        <button class="btn btn-sm btn-outline-secondary" @onclick="TogglePreviewAsync">
            <i class="bi bi-eye me-1"></i>@(showPreview ? "Hide preview" : "Preview")
        </button>
        @if (!IsNew)
        {
            <a href="newsletters/@NewsletterId/analytics" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-bar-chart me-1"></i>Analytics
            </a>
            <button class="btn btn-sm btn-outline-secondary" @onclick="SendTestEmailAsync" disabled="@sendingTest">
                @if (sendingTest) { <span class="spinner-border spinner-border-sm me-1"></span> }
                <i class="bi bi-send me-1"></i>Send test
            </button>
            <button class="btn btn-sm btn-outline-danger" @onclick="() => showDeleteConfirm = true" disabled="@saving">
                <i class="bi bi-trash me-1"></i>Delete
            </button>
        }
        <button class="btn btn-sm btn-primary" @onclick="SaveAsync" disabled="@saving">
            @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
            <i class="bi bi-check-lg me-1"></i>@(IsNew ? "Create" : "Save")
        </button>
    </div>
</div>

@if (!loaded)
{
    <p class="text-muted">Loading…</p>
}
else
{
    <div class="row g-4">
        <!-- Main Column -->
        <div class="col-lg-8">
            <!-- General Settings -->
            <div class="card">
                <div class="card-header"><h6 class="mb-0">General</h6></div>
                <div class="card-body">
                    <!-- Name -->
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input type="text" class="form-control" @bind="name" placeholder="Newsletter name" />
                    </div>

                    <!-- Slug -->
                    <div class="mb-3">
                        <label class="form-label">Slug</label>
                        <input type="text" class="form-control" @bind="slug" placeholder="auto-generated" />
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="2" @bind="description"
                                  placeholder="Short description for this newsletter…"></textarea>
                    </div>

                    <!-- Status -->
                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select class="form-select" @bind="status">
                            <option value="active">Active</option>
                            <option value="archived">Archived</option>
                        </select>
                    </div>

                    <!-- Sort Order -->
                    <div class="mb-3">
                        <label class="form-label">Sort order</label>
                        <input type="number" class="form-control" style="max-width: 120px" @bind="sortOrder" min="0" />
                    </div>

                    <!-- Subscribe on Signup -->
                    <div class="form-check mb-3">
                        <input type="checkbox" class="form-check-input" id="chkSubscribeOnSignup" @bind="subscribeOnSignup" />
                        <label class="form-check-label" for="chkSubscribeOnSignup">Subscribe on signup</label>
                        <div class="form-text">New free members are automatically subscribed to this newsletter.</div>
                    </div>

                    <!-- Archive page -->
                    <div class="form-check mb-0">
                        <input type="checkbox" class="form-check-input" id="chkArchiveEnabled" @bind="archiveEnabled" />
                        <label class="form-check-label" for="chkArchiveEnabled">Public archive page</label>
                        <div class="form-text">
                            Expose sent editions at
                            <code>/newsletter/@(string.IsNullOrWhiteSpace(slug) ? "{slug}" : slug)/archive/</code>
                            so visitors can browse past issues.
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sender Settings -->
            <div class="card mt-4">
                <div class="card-header"><h6 class="mb-0">Sender</h6></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Sender name</label>
                        <input type="text" class="form-control" @bind="senderName" placeholder="Site title" />
                        <div class="form-text">The name shown in the "From" field. Defaults to site title if empty.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Sender email</label>
                        <input type="email" class="form-control" @bind="senderEmail" placeholder="noreply@your-domain.com" />
                        <div class="form-text">The email address used in the "From" field.</div>
                    </div>

                    <div class="mb-0">
                        <label class="form-label">Reply-to address</label>
                        <select class="form-select" @bind="senderReplyTo">
                            <option value="newsletter">Newsletter address</option>
                            <option value="support">Support address</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Design Settings -->
            <div class="card mt-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Design</h6>
                    <button class="btn btn-sm btn-link text-muted p-0 text-decoration-none"
                            @onclick="() => showDesign = !showDesign">
                        <i class="bi @(showDesign ? "bi-chevron-up" : "bi-chevron-down")"></i>
                    </button>
                </div>
                @if (showDesign)
                {
                    <div class="card-body">
                        <!-- Header Section -->
                        <h6 class="text-muted small text-uppercase mb-3">Header</h6>

                        <!-- Header Image -->
                        <div class="mb-3">
                            <label class="form-label">Header image</label>
                            @if (!string.IsNullOrEmpty(headerImage))
                            {
                                <div class="feature-image-preview">
                                    <img src="@headerImage" alt="Header image" />
                                    <button class="btn btn-sm btn-danger feature-image-remove"
                                            @onclick="() => headerImage = null">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            }
                            else
                            {
                                <label class="feature-image-upload">
                                    <InputFile OnChange="UploadHeaderImageAsync" accept="image/*" />
                                    <i class="bi bi-image me-2"></i>Add header image
                                </label>
                            }
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="chkShowHeaderIcon"
                                           @bind="showHeaderIcon" />
                                    <label class="form-check-label" for="chkShowHeaderIcon">Show site icon</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="chkShowHeaderTitle"
                                           @bind="showHeaderTitle" />
                                    <label class="form-check-label" for="chkShowHeaderTitle">Show site title</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="chkShowHeaderName"
                                           @bind="showHeaderName" />
                                    <label class="form-check-label" for="chkShowHeaderName">Show newsletter name</label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Header background color</label>
                            <div class="input-group" style="max-width: 280px">
                                <input type="color" class="form-control form-control-color"
                                       value="@HeaderColorValue"
                                       @onchange="OnHeaderColorChanged" />
                                <input type="text" class="form-control" @bind="headerBackgroundColor" />
                                <button class="btn btn-outline-secondary"
                                        @onclick="ResetHeaderBackgroundColor">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                        </div>

                        <hr />

                        <!-- Typography -->
                        <h6 class="text-muted small text-uppercase mb-3">Typography</h6>

                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Title font</label>
                                <select class="form-select" @bind="titleFontCategory">
                                    <option value="sans_serif">Sans-serif</option>
                                    <option value="serif">Serif</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Title alignment</label>
                                <select class="form-select" @bind="titleAlignment">
                                    <option value="center">Center</option>
                                    <option value="left">Left</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Title weight</label>
                                <select class="form-select" @bind="titleFontWeight">
                                    <option value="bold">Bold</option>
                                    <option value="normal">Normal</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Body font</label>
                            <select class="form-select" style="max-width: 240px" @bind="bodyFontCategory">
                                <option value="sans_serif">Sans-serif</option>
                                <option value="serif">Serif</option>
                            </select>
                        </div>

                        <hr />

                        <!-- Content Display -->
                        <h6 class="text-muted small text-uppercase mb-3">Content</h6>

                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="chkShowFeatureImage"
                                           @bind="showFeatureImage" />
                                    <label class="form-check-label" for="chkShowFeatureImage">Feature image</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="chkShowExcerpt"
                                           @bind="showExcerpt" />
                                    <label class="form-check-label" for="chkShowExcerpt">Excerpt</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="chkShowPostTitleSection"
                                           @bind="showPostTitleSection" />
                                    <label class="form-check-label" for="chkShowPostTitleSection">Post title section</label>
                                </div>
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="chkShowCommentCta"
                                           @bind="showCommentCta" />
                                    <label class="form-check-label" for="chkShowCommentCta">Comment CTA</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="chkShowSubscriptionDetails"
                                           @bind="showSubscriptionDetails" />
                                    <label class="form-check-label" for="chkShowSubscriptionDetails">Subscription details</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="chkShowLatestPosts"
                                           @bind="showLatestPosts" />
                                    <label class="form-check-label" for="chkShowLatestPosts">Latest posts</label>
                                </div>
                            </div>
                        </div>

                        <hr />

                        <!-- Badge & Feedback -->
                        <h6 class="text-muted small text-uppercase mb-3">Badge &amp; Feedback</h6>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="chkShowBadge"
                                           @bind="showBadge" />
                                    <label class="form-check-label" for="chkShowBadge">Show badge</label>
                                    <div class="form-text">Show "Powered by Ghost" badge in footer.</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="chkFeedbackEnabled"
                                           @bind="feedbackEnabled" />
                                    <label class="form-check-label" for="chkFeedbackEnabled">Feedback enabled</label>
                                    <div class="form-text">Show feedback buttons (like/dislike) in emails.</div>
                                </div>
                            </div>
                        </div>

                        <hr />

                        <!-- Colors & Styling -->
                        <h6 class="text-muted small text-uppercase mb-3">Colors &amp; Styling</h6>

                        <div class="mb-3">
                            <label class="form-label">Background color</label>
                            <select class="form-select" style="max-width: 200px" @bind="backgroundColor">
                                <option value="light">Light</option>
                                <option value="dark">Dark</option>
                            </select>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label small">Post title color</label>
                                <div class="input-group" style="max-width: 240px">
                                    <input type="color" class="form-control form-control-color"
                                           value="@(postTitleColor ?? "#000000")"
                                           @onchange="e => postTitleColor = e.Value?.ToString()" />
                                    <input type="text" class="form-control" @bind="postTitleColor" placeholder="default" />
                                    @if (!string.IsNullOrEmpty(postTitleColor))
                                    {
                                        <button class="btn btn-outline-secondary" @onclick="() => postTitleColor = null">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small">Section title color</label>
                                <div class="input-group" style="max-width: 240px">
                                    <input type="color" class="form-control form-control-color"
                                           value="@(sectionTitleColor ?? "#000000")"
                                           @onchange="e => sectionTitleColor = e.Value?.ToString()" />
                                    <input type="text" class="form-control" @bind="sectionTitleColor" placeholder="default" />
                                    @if (!string.IsNullOrEmpty(sectionTitleColor))
                                    {
                                        <button class="btn btn-outline-secondary" @onclick="() => sectionTitleColor = null">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label small">Divider color</label>
                                <div class="input-group" style="max-width: 240px">
                                    <input type="color" class="form-control form-control-color"
                                           value="@(dividerColor ?? "#e5e7eb")"
                                           @onchange="e => dividerColor = e.Value?.ToString()" />
                                    <input type="text" class="form-control" @bind="dividerColor" placeholder="default" />
                                    @if (!string.IsNullOrEmpty(dividerColor))
                                    {
                                        <button class="btn btn-outline-secondary" @onclick="() => dividerColor = null">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small">Button color</label>
                                <div class="input-group" style="max-width: 240px">
                                    <input type="text" class="form-control" @bind="buttonColor"
                                           placeholder="accent" />
                                    @if (!string.IsNullOrEmpty(buttonColor) && buttonColor != "accent")
                                    {
                                        <button class="btn btn-outline-secondary" @onclick="ResetButtonColor">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    }
                                </div>
                                <div class="form-text">Use "accent" for site accent color, or a hex value.</div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small">Link color</label>
                            <div class="input-group" style="max-width: 240px">
                                <input type="text" class="form-control" @bind="linkColor" placeholder="accent" />
                                @if (!string.IsNullOrEmpty(linkColor) && linkColor != "accent")
                                {
                                    <button class="btn btn-outline-secondary" @onclick="ResetLinkColor">
                                        <i class="bi bi-x"></i>
                                    </button>
                                }
                            </div>
                        </div>

                        <hr />

                        <!-- Element Styles -->
                        <h6 class="text-muted small text-uppercase mb-3">Element Styles</h6>

                        <div class="row g-3 mb-3">
                            <div class="col-md-3">
                                <label class="form-label small">Button corners</label>
                                <select class="form-select form-select-sm" @bind="buttonCorners">
                                    <option value="rounded">Rounded</option>
                                    <option value="square">Square</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Button style</label>
                                <select class="form-select form-select-sm" @bind="buttonStyle">
                                    <option value="fill">Fill</option>
                                    <option value="outline">Outline</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Link style</label>
                                <select class="form-select form-select-sm" @bind="linkStyle">
                                    <option value="underline">Underline</option>
                                    <option value="none">None</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Image corners</label>
                                <select class="form-select form-select-sm" @bind="imageCorners">
                                    <option value="square">Square</option>
                                    <option value="rounded">Rounded</option>
                                </select>
                            </div>
                        </div>

                        <hr />

                        <!-- Footer -->
                        <h6 class="text-muted small text-uppercase mb-3">Footer</h6>

                        <div class="mb-0">
                            <label class="form-label">Footer content</label>
                            <textarea class="form-control" rows="3" @bind="footerContent"
                                      placeholder="Custom footer text shown below each email…"></textarea>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            @if (!IsNew && newsletter is not null)
            {
                <div class="card">
                    <div class="card-body">
                        <h6>Newsletter details</h6>
                        <dl class="small mb-0">
                            <dt class="text-muted">ID</dt>
                            <dd class="font-monospace small">@newsletter.Id</dd>

                            <dt class="text-muted">Slug</dt>
                            <dd>@newsletter.Slug</dd>

                            <dt class="text-muted">Status</dt>
                            <dd>
                                <span class="badge @(newsletter.Status == "active" ? "bg-success" : "bg-secondary")">
                                    @newsletter.Status
                                </span>
                            </dd>

                            <dt class="text-muted">Subscribers</dt>
                            <dd>@subscriberCount</dd>

                            <dt class="text-muted">Created</dt>
                            <dd>@newsletter.CreatedAt.ToString("MMM d, yyyy HH:mm")</dd>

                            @if (newsletter.UpdatedAt.HasValue)
                            {
                                <dt class="text-muted">Updated</dt>
                                <dd>@newsletter.UpdatedAt.Value.ToString("MMM d, yyyy HH:mm")</dd>
                            }
                        </dl>
                    </div>
                </div>
            }

            <!-- Visibility -->
            @if (!IsNew)
            {
                <div class="card mt-4">
                    <div class="card-body">
                        <h6>Visibility</h6>
                        <select class="form-select" @bind="visibility">
                            <option value="members">Members</option>
                            <option value="paid">Paid members</option>
                        </select>
                        <div class="form-text mt-2">Controls who can subscribe to this newsletter.</div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Live Email Preview Modal -->
@if (showPreview)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable" style="max-width: min(900px, 95vw);">
            <div class="modal-content" style="height: 90vh;">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-envelope me-2"></i>Email preview
                        @if (previewLoading)
                        {
                            <span class="spinner-border spinner-border-sm ms-2" role="status"></span>
                        }
                    </h5>
                    <div class="d-flex align-items-center gap-2">
                        <small class="text-muted me-2">Updates live as you edit design settings.</small>
                        <button type="button" class="btn-close" @onclick="() => showPreview = false"></button>
                    </div>
                </div>
                <div class="modal-body p-0" style="background: #f3f4f6; overflow: hidden;">
                    @if (!string.IsNullOrEmpty(previewError))
                    {
                        <div class="alert alert-danger m-3 mb-0">
                            <i class="bi bi-exclamation-triangle me-1"></i>@previewError
                        </div>
                    }
                    else if (string.IsNullOrEmpty(previewHtml))
                    {
                        <div class="d-flex justify-content-center align-items-center text-muted" style="height: 100%;">
                            <span class="spinner-border spinner-border-sm me-2"></span> Rendering preview…
                        </div>
                    }
                    else
                    {
                        <iframe srcdoc="@previewHtml"
                                sandbox="allow-same-origin"
                                style="width: 100%; height: 100%; border: 0; background: white;"
                                title="Email preview"></iframe>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
@if (showDeleteConfirm)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete newsletter</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteConfirm = false"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete the newsletter <strong>@name</strong>?
                       All subscriber associations will be removed. This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancel</button>
                    <button class="btn btn-danger" @onclick="DeleteAsync">
                        <i class="bi bi-trash-fill me-1"></i>Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string? NewsletterId { get; set; }

    private bool IsNew => string.IsNullOrEmpty(NewsletterId);

    // State
    private Newsletter? newsletter;
    private bool loaded;
    private bool saving;
    private bool sendingTest;
    private bool showDesign = true;
    private bool showDeleteConfirm;
    private string? statusMessage;
    private bool isError;
    private int subscriberCount;

    // Preview state
    private bool showPreview;
    private string? previewHtml;
    private bool previewLoading;
    private string? previewError;
    private string? lastPreviewKey;
    private System.Threading.CancellationTokenSource? previewCts;

    // General fields
    private string name = "";
    private string slug = "";
    private string? description;
    private string status = "active";
    private int sortOrder;
    private bool subscribeOnSignup = true;
    private bool archiveEnabled;
    private string visibility = "members";

    // Sender fields
    private string? senderName;
    private string? senderEmail;
    private string senderReplyTo = "newsletter";

    // Design - Header
    private string? headerImage;
    private bool showHeaderIcon = true;
    private bool showHeaderTitle = true;
    private bool showHeaderName = true;
    private string headerBackgroundColor = "transparent";

    // Design - Typography
    private string titleFontCategory = "sans_serif";
    private string titleAlignment = "center";
    private string titleFontWeight = "bold";
    private string bodyFontCategory = "sans_serif";

    // Design - Content
    private bool showFeatureImage = true;
    private bool showExcerpt;
    private bool showPostTitleSection = true;

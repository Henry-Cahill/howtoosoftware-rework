    private async Task SaveAsync()
    {
        statusMessage = null;
        isError = false;

        if (string.IsNullOrWhiteSpace(name))
        {
            statusMessage = "Name is required.";
            isError = true;
            return;
        }

        saving = true;
        try
        {
            slug = string.IsNullOrWhiteSpace(slug)
                ? SlugGenerator.GenerateSlug(name)
                : SlugGenerator.GenerateSlug(slug);

            // Check for duplicate slug
            var existing = await NewsletterRepository.GetBySlugAsync(slug);
            if (existing is not null && existing.Id != (newsletter?.Id ?? ""))
            {
                var baseSlug = slug;
                var counter = 2;
                do
                {
                    slug = $"{baseSlug}-{counter}";
                    existing = await NewsletterRepository.GetBySlugAsync(slug);
                    counter++;
                } while (existing is not null && existing.Id != (newsletter?.Id ?? ""));
            }

            if (IsNew)
            {
                newsletter = new Newsletter
                {
                    Id = Guid.NewGuid().ToString("N")[..24],
                    Uuid = Guid.NewGuid().ToString(),
                    CreatedAt = DateTime.UtcNow,
                };
                ApplyFormToNewsletter(newsletter);
                await NewsletterRepository.AddAsync(newsletter);
                statusMessage = "Newsletter created!";
                Navigation.NavigateTo($"newsletters/{newsletter.Id}/edit", replace: true);
            }
            else
            {
                ApplyFormToNewsletter(newsletter!);
                await NewsletterRepository.UpdateAsync(newsletter!);
                statusMessage = "Newsletter saved!";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
            isError = true;
        }
        finally
        {
            saving = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (newsletter is null) return;
        await NewsletterRepository.DeleteAsync(newsletter.Id);
        Navigation.NavigateTo("newsletters");
    }

    private async Task SendTestEmailAsync()
    {
        statusMessage = null;
        isError = false;
        sendingTest = true;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value;

            if (string.IsNullOrEmpty(userEmail))
            {
                statusMessage = "Could not determine your email address.";
                isError = true;
                return;
            }

            var siteTitle = await SettingsService.GetStringAsync("title") ?? "HowToSoftware";
            var siteUrl = await SettingsService.GetStringAsync("url") ?? "https://howtoosoftware.com";
            var siteIcon = await SettingsService.GetStringAsync("icon");

            var model = new EmailTemplateModel
            {
                SiteTitle = siteTitle,
                SiteUrl = siteUrl,
                SiteIconUrl = siteIcon,
                HeaderImage = headerImage,
                PostTitle = "Test Newsletter Email",
                PostUrl = siteUrl,
                HtmlBody = "<p>This is a <strong>test email</strong> for the newsletter " +
                           $"<em>{System.Net.WebUtility.HtmlEncode(name)}</em>. " +
                           "If you're reading this, email delivery is working correctly.</p>",
                FooterContent = footerContent,
                ShowBadge = showBadge,
                ShowHeaderIcon = showHeaderIcon,
                ShowHeaderTitle = showHeaderTitle,
                ShowFeatureImage = false,
                ShowExcerpt = showExcerpt,
                AccentColor = await SettingsService.GetStringAsync("accent_color"),
                BackgroundColor = backgroundColor,
                TitleFontCategory = titleFontCategory,
                TitleAlignment = titleAlignment,
                BodyFontCategory = bodyFontCategory,
                PublishedAt = DateTime.UtcNow,
            };

            var html = await EmailService.RenderTemplateAsync("newsletter", model);

            var fromAddress = !string.IsNullOrEmpty(senderEmail)
                ? senderEmail
                : $"noreply@{siteUrl.Replace("https://", "").Replace("http://", "").Split('/')[0]}";

            var fromName = !string.IsNullOrEmpty(senderName) ? senderName : siteTitle;

            var result = await EmailService.SendAsync(new EmailMessage
            {
                From = $"{fromName} <{fromAddress}>",
                To = userEmail,
                Subject = $"[TEST] {name}",
                Html = html,
            });

            if (result.Success)
            {
                statusMessage = $"Test email sent to {userEmail}!";
            }
            else
            {
                statusMessage = $"Failed to send: {result.ErrorMessage}";
                isError = true;
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Error sending test: {ex.Message}";
            isError = true;
        }
        finally
        {
            sendingTest = false;
        }
    }

    private async Task UploadHeaderImageAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > 10 * 1024 * 1024)
        {
            statusMessage = "Image must be under 10 MB.";
            isError = true;
            return;
        }
        using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        var result = await ImageStorage.UploadAsync(stream, file.Name, file.ContentType);
        headerImage = result.Url;
    }


    private async Task TogglePreviewAsync()
    {
        showPreview = !showPreview;
        if (showPreview)
        {
            await RefreshPreviewAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!showPreview || previewLoading) return;

        var key = BuildPreviewKey();
        if (key == lastPreviewKey) return;

        await RefreshPreviewAsync();
    }

    private async Task RefreshPreviewAsync()
    {
        // Cancel any in-flight render so we always converge on the latest state.
        previewCts?.Cancel();
        var cts = new System.Threading.CancellationTokenSource();
        previewCts = cts;

        previewLoading = true;
        previewError = null;
        var key = BuildPreviewKey();
        StateHasChanged();

        try
        {
            var siteTitle = await SettingsService.GetStringAsync("title") ?? "HowToSoftware";
            var siteUrl = await SettingsService.GetStringAsync("url") ?? "https://howtoosoftware.com";
            var siteIcon = await SettingsService.GetStringAsync("icon");
            var accent = await SettingsService.GetStringAsync("accent_color");

            if (cts.IsCancellationRequested) return;

            var model = new EmailTemplateModel
            {
                SiteTitle = siteTitle,
                SiteUrl = siteUrl,
                SiteIconUrl = siteIcon,
                AccentColor = accent,

                PostTitle = "Sample post title for preview",
                PostUrl = siteUrl,
                FeatureImage = showFeatureImage
                    ? "https://images.unsplash.com/photo-1499951360447-b19be8fe80f5?auto=format&fit=crop&w=1200&q=60"
                    : null,
                AuthorName = "Jane Doe",
                Excerpt = "This short excerpt previews how excerpts will render in your newsletter when enabled.",
                PublishedAt = DateTime.UtcNow,
                HtmlBody =
                    "<p>This is a <strong>live preview</strong> of your newsletter design. " +
                    "Toggle any design setting on the left and this preview will update automatically.</p>" +
                    "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Phasellus vitae ipsum " +
                    "id nulla porta facilisis. <a href=\"#\">Sample link</a> shows how links are styled.</p>" +
                    "<blockquote><p>\u201CSample quote to demonstrate blockquote styling within the email body.\u201D</p></blockquote>" +
                    "<p>And one more paragraph so you can see paragraph spacing and body typography.</p>" +
                    "<p style=\"text-align:center\"><a href=\"#\" class=\"btn\" " +
                    "style=\"display:inline-block;padding:12px 24px;background:#0d6efd;color:#fff;" +
                    "text-decoration:none;border-radius:4px;\">Sample button</a></p>",

                HeaderImage = headerImage,
                ShowBadge = showBadge,
                ShowHeaderIcon = showHeaderIcon,
                ShowHeaderTitle = showHeaderTitle,
                ShowHeaderName = showHeaderName,
                ShowFeatureImage = showFeatureImage,
                ShowExcerpt = showExcerpt,
                ShowPostTitleSection = showPostTitleSection,
                ShowCommentCta = showCommentCta,
                FeedbackEnabled = feedbackEnabled,

                BackgroundColor = backgroundColor,
                TitleFontCategory = titleFontCategory,
                TitleAlignment = titleAlignment,
                TitleFontWeight = titleFontWeight,
                PostTitleColor = postTitleColor,
                BodyFontCategory = bodyFontCategory,
                HeaderBackgroundColor = headerBackgroundColor,
                DividerColor = dividerColor,

                ButtonCorners = buttonCorners,
                ButtonStyle = buttonStyle,
                ButtonColor = buttonColor,
                LinkStyle = linkStyle,
                LinkColor = linkColor,
                ImageCorners = imageCorners,

                FooterContent = footerContent,
                UnsubscribeUrl = "#",
                ManageSubscriptionUrl = "#",
                CommentUrl = "#",
            };

            var html = await EmailService.RenderTemplateAsync("newsletter", model, cts.Token);
            if (cts.IsCancellationRequested) return;

            previewHtml = html;
            lastPreviewKey = key;
        }
        catch (OperationCanceledException)
        {
            // Superseded by a newer render; ignore.
        }
        catch (Exception ex)
        {
            previewError = $"Failed to render preview: {ex.Message}";
        }
        finally
        {
            if (previewCts == cts)
            {
                previewLoading = false;
                StateHasChanged();
            }
        }
    }

    // Stable key derived from every form field that affects the rendered email,
    // so OnAfterRenderAsync can detect when a re-render is needed.
    private string BuildPreviewKey() => string.Join("|",
        headerImage, showHeaderIcon, showHeaderTitle, showHeaderName, headerBackgroundColor,
        titleFontCategory, titleAlignment, titleFontWeight, bodyFontCategory,
        showFeatureImage, showExcerpt, showPostTitleSection, showCommentCta,
        showSubscriptionDetails, showLatestPosts, showBadge, feedbackEnabled,
        backgroundColor, postTitleColor, sectionTitleColor, dividerColor, buttonColor, linkColor,
        buttonCorners, buttonStyle, linkStyle, imageCorners,
        footerContent, name);

    // Helpers for Razor-safe event handlers
    private string HeaderColorValue => headerBackgroundColor == "transparent" ? "#ffffff" : headerBackgroundColor;
    private void OnHeaderColorChanged(ChangeEventArgs e) => headerBackgroundColor = e.Value?.ToString() ?? "transparent";
    private void ResetHeaderBackgroundColor() => headerBackgroundColor = "transparent";
    private void ResetButtonColor() => buttonColor = "accent";
    private void ResetLinkColor() => linkColor = "accent";

    private static string? TrimOrNull(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

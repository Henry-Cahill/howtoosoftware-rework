@page "/recommendations/new"
@page "/recommendations/{RecommendationId}/edit"
@using HowToSoftware.Core.Entities
@using HowToSoftware.Core.Interfaces
@attribute [Authorize(Roles = "Owner,Administrator")]
@inject IRecommendationService RecommendationService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(IsNew ? "New Recommendation" : $"Edit — {title}") — HowToSoftware Admin</PageTitle>

<!-- Top Bar -->
<div class="editor-topbar">
    <div class="d-flex align-items-center gap-2">
        <a href="recommendations" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Recommendations
        </a>
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <span class="@(isError ? "text-danger" : "text-success") small">
                <i class="bi @(isError ? "bi-exclamation-circle" : "bi-check-circle") me-1"></i>@statusMessage
            </span>
        }
    </div>
    <div class="d-flex align-items-center gap-2">
        @if (!IsNew)
        {
            <button class="btn btn-sm btn-outline-danger" @onclick="() => showDeleteConfirm = true" disabled="@saving">
                <i class="bi bi-trash me-1"></i>Delete
            </button>
        }
        <button class="btn btn-sm btn-primary" @onclick="SaveAsync" disabled="@saving">
            @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
            <i class="bi bi-check-lg me-1"></i>@(IsNew ? "Create" : "Save")
        </button>
    </div>
</div>

<!-- Delete Confirmation Modal -->
@if (showDeleteConfirm)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete Recommendation</h5>
                    <button type="button" class="btn-close" @onclick="() => showDeleteConfirm = false"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete <strong>@title</strong>? This will also remove all associated click and subscribe events. This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancel</button>
                    <button class="btn btn-danger" @onclick="DeleteAsync">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (!loaded)
{
    <p class="text-muted">Loading…</p>
}
else
{
    <div class="row g-4">
        <!-- Main Column -->
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-header"><h6 class="mb-0">Recommendation details</h6></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input type="text" class="form-control" @bind="title" placeholder="e.g. The Verge" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">URL</label>
                        <input type="url" class="form-control" @bind="url" placeholder="https://example.com" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Excerpt</label>
                        <input type="text" class="form-control" @bind="excerpt" placeholder="Short description" />
                        <div class="form-text">A brief one-line summary shown alongside the recommendation.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="3" @bind="description" placeholder="Longer description (optional)"></textarea>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header"><h6 class="mb-0">Branding</h6></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Favicon URL</label>
                        <input type="url" class="form-control" @bind="favicon" placeholder="https://example.com/favicon.ico" />
                        <div class="form-text">Small icon displayed next to the recommendation.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Featured image URL</label>
                        <input type="url" class="form-control" @bind="featuredImage" placeholder="https://example.com/image.jpg" />
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="oneClickSubscribe" @bind="oneClickSubscribe" />
                        <label class="form-check-label" for="oneClickSubscribe">
                            Enable one-click subscribe
                        </label>
                        <div class="form-text">Allow visitors to subscribe to this publication with a single click.</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            @if (!IsNew && recommendation is not null)
            {
                <!-- Analytics Card -->
                <div class="card mb-3">
                    <div class="card-header"><h6 class="mb-0">Analytics</h6></div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-6">
                                <div class="fs-3 fw-bold">@clickCount</div>
                                <div class="small text-muted">Clicks</div>
                            </div>
                            <div class="col-6">
                                <div class="fs-3 fw-bold">@subscribeCount</div>
                                <div class="small text-muted">Subscribes</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Info Card -->
                <div class="card">
                    <div class="card-header"><h6 class="mb-0">Info</h6></div>
                    <div class="card-body small text-muted">
                        <div>Created: @recommendation.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                        @if (recommendation.UpdatedAt.HasValue)
                        {
                            <div>Updated: @recommendation.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm")</div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string? RecommendationId { get; set; }

    private bool IsNew => string.IsNullOrEmpty(RecommendationId);
    private bool loaded;
    private bool saving;
    private string? statusMessage;
    private bool isError;
    private bool showDeleteConfirm;

    private Recommendation? recommendation;

    private string title = "";
    private string url = "";
    private string? excerpt;
    private string? description;
    private string? favicon;
    private string? featuredImage;
    private bool oneClickSubscribe;
    private int clickCount;
    private int subscribeCount;

    protected override async Task OnInitializedAsync()
    {
        if (!IsNew)
        {
            recommendation = await RecommendationService.GetByIdAsync(RecommendationId!);
            if (recommendation is null)
            {
                Navigation.NavigateTo("recommendations");
                return;
            }

            title = recommendation.Title;
            url = recommendation.Url;
            excerpt = recommendation.Excerpt;
            description = recommendation.Description;
            favicon = recommendation.Favicon;
            featuredImage = recommendation.FeaturedImage;
            oneClickSubscribe = recommendation.OneClickSubscribe;
            clickCount = await RecommendationService.GetClickCountAsync(recommendation.Id);
            subscribeCount = await RecommendationService.GetSubscribeCountAsync(recommendation.Id);
        }

        loaded = true;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(title) || string.IsNullOrWhiteSpace(url))
        {
            statusMessage = "Title and URL are required.";
            isError = true;
            return;
        }

        saving = true;
        statusMessage = null;

        try
        {
            if (IsNew)
            {
                var created = await RecommendationService.CreateAsync(new CreateRecommendationRequest
                {
                    Title = title,
                    Url = url,
                    Excerpt = excerpt,
                    Description = description,
                    Favicon = favicon,
                    FeaturedImage = featuredImage,
                    OneClickSubscribe = oneClickSubscribe,
                });

                Navigation.NavigateTo($"recommendations/{created.Id}/edit");
            }
            else
            {
                await RecommendationService.UpdateAsync(RecommendationId!, new UpdateRecommendationRequest
                {
                    Title = title,
                    Url = url,
                    Excerpt = excerpt,
                    Description = description,
                    Favicon = favicon,
                    FeaturedImage = featuredImage,
                    OneClickSubscribe = oneClickSubscribe,
                });

                statusMessage = "Saved";
                isError = false;
            }
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
            isError = true;
        }
        finally
        {
            saving = false;
        }
    }

    private async Task DeleteAsync()
    {
        try
        {
            await RecommendationService.DeleteAsync(RecommendationId!);
            Navigation.NavigateTo("recommendations");
        }
        catch (Exception ex)
        {
            showDeleteConfirm = false;
            statusMessage = ex.Message;
            isError = true;
        }
    }
}


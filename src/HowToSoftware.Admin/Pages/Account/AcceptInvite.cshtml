@page "/account/accept-invite"
@model HowToSoftware.Admin.Pages.Account.AcceptInviteModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Accept invitation — HowToSoftware</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #15171a;
            color: #fff;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }
        .invite-card {
            background-color: #1e2025;
            border-radius: 6px;
            padding: 2.5rem;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
        }
        .invite-card h1 {
            font-size: 1.6rem;
            font-weight: 700;
            margin-bottom: 0.25rem;
            text-align: center;
        }
        .invite-card .subtitle {
            color: #a0a0a0;
            text-align: center;
            margin-bottom: 1.75rem;
            font-size: 0.9rem;
        }
        .form-label {
            color: #a0a0a0;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .form-control {
            background-color: #2a2d32;
            border: 1px solid #394046;
            color: #fff;
            padding: 0.6rem 0.75rem;
        }
        .form-control:focus {
            background-color: #2a2d32;
            border-color: #a78bfa;
            color: #fff;
            box-shadow: 0 0 0 0.2rem rgba(167, 139, 250, 0.25);
        }
        .form-control[readonly] {
            opacity: 0.7;
        }
        .btn-accept {
            background-color: #a78bfa;
            border: none;
            color: #fff;
            font-weight: 600;
            padding: 0.6rem;
            width: 100%;
            border-radius: 4px;
            font-size: 0.95rem;
        }
        .btn-accept:hover {
            background-color: #8b6de0;
            color: #fff;
        }
        .btn-accept:disabled {
            opacity: 0.6;
        }
        .alert-danger {
            background-color: #3d1f24;
            border-color: #6b2c34;
            color: #f8a0a0;
            font-size: 0.875rem;
        }
        .text-validation {
            color: #f8a0a0;
            font-size: 0.8rem;
        }
        .role-pill {
            display: inline-block;
            background: #2a2d32;
            color: #a78bfa;
            border-radius: 999px;
            padding: 0.15rem 0.65rem;
            font-size: 0.78rem;
            font-weight: 600;
            margin-left: 0.25rem;
        }
    </style>
</head>
<body>
    <div class="invite-card">
        <h1>Accept invitation</h1>
        <p class="subtitle">
            @if (!string.IsNullOrEmpty(Model.RoleName))
            {
                <text>Create your account as <span class="role-pill">@Model.RoleName</span></text>
            }
            else
            {
                <text>Create your account</text>
            }
        </p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">
                @Model.ErrorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Email))
        {
            <form method="post">
                <input type="hidden" asp-for="Token" />

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control" type="email" readonly />
                </div>
                <div class="mb-3">
                    <label asp-for="Input.Name" class="form-label">Full name</label>
                    <input asp-for="Input.Name" class="form-control" autocomplete="name" autofocus required />
                    <span asp-validation-for="Input.Name" class="text-validation"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <input asp-for="Input.Password" class="form-control" type="password" autocomplete="new-password" required />
                    <span asp-validation-for="Input.Password" class="text-validation"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Input.ConfirmPassword" class="form-label">Confirm password</label>
                    <input asp-for="Input.ConfirmPassword" class="form-control" type="password" autocomplete="new-password" required />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-validation"></span>
                </div>
                <button type="submit" class="btn btn-accept">Create account & sign in</button>
            </form>
        }
    </div>
</body>
</html>


@* 401 Unauthorized — ported from error-401.hbs *@

<style>
    .error-page-401 {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 4rem 2rem;
        background: linear-gradient(135deg, #e6fffa 0%, #b2f5ea 100%);
    }

    [data-theme="dark"] .error-page-401 {
        background: linear-gradient(135deg, #1a1a2e 0%, #1d3a3a 100%);
    }

    .error-page-401 .error-container { max-width: 600px; }

    .error-page-401 .error-gif {
        width: 100%;
        max-width: 350px;
        border-radius: 16px;
        margin-bottom: 2rem;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    }

    .error-page-401 .error-code {
        font-size: 8rem;
        font-weight: 800;
        margin: 0;
        background: linear-gradient(135deg, #38b2ac 0%, #319795 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1;
    }

    .error-page-401 .error-title {
        font-size: 2rem;
        font-weight: 700;
        margin: 1rem 0;
        color: var(--color-darkgrey);
    }

    .error-page-401 .error-description {
        font-size: 1.2rem;
        color: var(--color-midgrey);
        margin-bottom: 2rem;
        line-height: 1.6;
    }

    .error-page-401 .error-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .error-page-401 .error-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.875rem 1.75rem;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .error-page-401 .error-btn-primary {
        background: linear-gradient(135deg, #38b2ac 0%, #319795 100%);
        color: white;
    }

    .error-page-401 .error-btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 20px rgba(56, 178, 172, 0.4);
        color: white;
    }

    .error-page-401 .error-btn-secondary {
        background: white;
        color: var(--color-darkgrey);
        border: 2px solid #e2e8f0;
    }

    .error-page-401 .bouncer-says {
        margin-top: 2rem;
        padding: 1.5rem;
        background: rgba(255,255,255,0.5);
        border-radius: 12px;
        border-left: 4px solid #38b2ac;
    }

    [data-theme="dark"] .error-page-401 .bouncer-says {
        background: rgba(0,0,0,0.2);
    }

    .error-page-401 .bouncer-says strong {
        display: block;
        margin-bottom: 0.5rem;
        color: #319795;
    }
</style>

<section class="error-page-401 outer">
    <div class="error-container inner">
        <img
            src="https://media.giphy.com/media/njYrp176NQsHS/giphy.gif"
            alt="Gandalf - You shall not pass!"
            class="error-gif"
            loading="lazy"
        />

        <h1 class="error-code">401</h1>
        <h2 class="error-title">Unauthorized</h2>
        <p class="error-description">
            Hold up! 🛑 You need to prove who you are first.<br>
            This VIP section requires credentials, friend.
        </p>

        <div class="error-actions">
            <a href="/signin" class="error-btn error-btn-primary">
                🔑 Sign In
            </a>
            <a href="/" class="error-btn error-btn-secondary">
                🏠 Go Home
            </a>
        </div>

        <div class="bouncer-says">
            <strong>🕴️ Bouncer says:</strong>
            "Name's not on the list, mate. Got any ID?"
        </div>
    </div>
</section>


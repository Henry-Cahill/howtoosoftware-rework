@* 404 Page Not Found — ported from error-404.hbs *@

<style>
    .error-page-404 {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 4rem 2rem;
    }

    .error-page-404 .error-container {
        max-width: 600px;
    }

    .error-page-404 .error-gif {
        width: 100%;
        max-width: 400px;
        border-radius: 16px;
        margin-bottom: 2rem;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    }

    .error-page-404 .error-code {
        font-size: 8rem;
        font-weight: 800;
        margin: 0;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1;
    }

    .error-page-404 .error-title {
        font-size: 2rem;
        font-weight: 700;
        margin: 1rem 0;
        color: var(--color-darkgrey);
    }

    .error-page-404 .error-description {
        font-size: 1.2rem;
        color: var(--color-midgrey);
        margin-bottom: 2rem;
        line-height: 1.6;
    }

    .error-page-404 .error-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .error-page-404 .error-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.875rem 1.75rem;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .error-page-404 .error-btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .error-page-404 .error-btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4);
        color: white;
    }

    .error-page-404 .error-btn-secondary {
        background: var(--color-lightgrey);
        color: var(--color-darkgrey);
    }

    .error-page-404 .error-btn-secondary:hover {
        background: var(--color-midgrey);
        color: white;
    }

    .error-page-404 .error-suggestion {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--color-lightgrey);
    }

    .error-page-404 .error-suggestion h3 {
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-midgrey);
        margin-bottom: 1rem;
    }

    [data-theme="dark"] .error-page-404 .error-title {
        color: var(--color-white);
    }

    [data-theme="dark"] .error-page-404 .error-btn-secondary {
        background: rgba(255, 255, 255, 0.1);
        color: var(--color-white);
    }

    [data-theme="dark"] .error-page-404 .error-btn-secondary:hover {
        background: rgba(255, 255, 255, 0.2);
    }
</style>

<section class="error-page-404 outer">
    <div class="error-container inner">
        <img
            src="https://media.giphy.com/media/hEc4k5pN17GZq/giphy.gif"
            alt="John Travolta looking confused"
            class="error-gif"
            loading="lazy"
        />

        <h1 class="error-code">404</h1>
        <h2 class="error-title">Page Not Found</h2>
        <p class="error-description">
            Looks like this page pulled a disappearing act! 🎩✨<br>
            Don't worry, even the best explorers get lost sometimes.
        </p>

        <div class="error-actions">
            <a href="/" class="error-btn error-btn-primary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                    <polyline points="9 22 9 12 15 12 15 22"></polyline>
                </svg>
                Go Home
            </a>
            <a href="javascript:history.back()" class="error-btn error-btn-secondary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Go Back
            </a>
        </div>

        <div class="error-suggestion">
            <h3>Maybe try one of these?</h3>
        </div>
    </div>
</section>


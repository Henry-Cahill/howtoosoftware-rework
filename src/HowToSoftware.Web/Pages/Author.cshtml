@page "/author/{slug}"
@model AuthorModel
@{
    var author = Model.Author;
}

<main id="site-main" class="site-main outer">
<div class="inner posts">

    <div class="post-feed">

        @* ── Author profile card (large) ── *@
        <section class="post-card post-card-large">

            @if (!string.IsNullOrEmpty(author.CoverImage))
            {
                <div class="post-card-image-link">
                    <img class="post-card-image"
                         srcset="@(author.CoverImage)?w=300 300w,
                                 @(author.CoverImage)?w=600 600w,
                                 @(author.CoverImage)?w=1000 1000w,
                                 @(author.CoverImage)?w=2000 2000w"
                         sizes="(max-width: 1000px) 400px, 800px"
                         src="@(author.CoverImage)?w=600"
                         alt="@author.Name" />
                </div>
            }

            <div class="post-card-content">
            <div class="post-card-content-link">

                @if (!string.IsNullOrEmpty(author.ProfileImage))
                {
                    <img class="author-profile-pic" src="@author.ProfileImage" alt="@author.Name" />
                }

                <header class="post-card-header">
                    <h2 class="post-card-title">@author.Name</h2>
                </header>

                @if (!string.IsNullOrEmpty(author.Bio))
                {
                    <div class="post-card-excerpt">@author.Bio</div>
                }

                <footer class="author-profile-footer">
                    @if (!string.IsNullOrEmpty(author.Location))
                    {
                        <div class="author-profile-location">@author.Location</div>
                    }
                    <div class="author-profile-meta">
                        @if (!string.IsNullOrEmpty(author.Website))
                        {
                            <a class="author-profile-social-link" href="@author.Website" target="_blank" rel="noopener">@author.Website</a>
                        }
                        @if (!string.IsNullOrEmpty(author.Twitter))
                        {
                            <a class="author-profile-social-link" href="https://twitter.com/@(author.Twitter.TrimStart('@'))" target="_blank" rel="noopener">
                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor" width="16" height="16"><path d="M23.954 4.569a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.691 8.094 4.066 6.13 1.64 3.161a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.061a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.937 4.937 0 004.604 3.417 9.868 9.868 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.054 0 13.999-7.496 13.999-13.986 0-.209 0-.42-.015-.63a9.936 9.936 0 002.46-2.548l-.047-.02z"/></svg>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(author.Facebook))
                        {
                            <a class="author-profile-social-link" href="https://facebook.com/@author.Facebook" target="_blank" rel="noopener">
                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor" width="16" height="16"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(author.LinkedIn))
                        {
                            <a class="author-profile-social-link" href="https://linkedin.com/in/@author.LinkedIn" target="_blank" rel="noopener">
                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor" width="16" height="16"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                            </a>
                        }
                    </div>
                </footer>

            </div>
            </div>

        </section>

        @* ── Author's posts ── *@
        @foreach (var card in Model.PostCards)
        {
            <partial name="_PostCard" model="card" />
        }

    </div>

    @* ── Pagination ── *@
    @{
        var authorPagination = new HowToSoftware.Web.Models.PaginationViewModel
        {
            CurrentPage = Model.CurrentPage,
            TotalPages = Model.TotalPages,
            HasPreviousPage = Model.HasPreviousPage,
            HasNextPage = Model.HasNextPage,
            BaseUrl = "/author/" + author.Slug + "/"
        };
    }
    <partial name="_Pagination" model="authorPagination" />

</div>
</main>


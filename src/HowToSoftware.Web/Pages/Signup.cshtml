@page "/signup"
@model HowToSoftware.Web.Pages.SignupModel
@{
    ViewData["Title"] = "Subscribe";
    ViewData["BodyClass"] = "signup-page";
}

<main class="site-main">
    <article class="gh-article">
        <div class="gh-article-header gh-canvas" style="text-align:center;padding:6rem 0 3rem;">
            <h1 class="gh-article-title">Subscribe to @Model.SiteTitle</h1>
            <p class="gh-article-excerpt" style="margin-top:1rem;font-size:1.8rem;color:var(--color-text-secondary);">
                Get the latest posts delivered right to your inbox.
            </p>
        </div>

        <div class="gh-content gh-canvas" style="max-width:440px;margin:0 auto;padding-bottom:6rem;">
            @if (Model.SuccessMessage is not null)
            {
                <div style="background:var(--color-primary);color:white;padding:1.6rem 2rem;border-radius:8px;text-align:center;margin-bottom:2rem;font-size:1.5rem;">
                    @Model.SuccessMessage
                </div>
            }
            else
            {
                @if (Model.ErrorMessage is not null)
                {
                    <div style="background:#dc3545;color:white;padding:1.2rem 2rem;border-radius:8px;text-align:center;margin-bottom:2rem;font-size:1.4rem;">
                        @Model.ErrorMessage
                    </div>
                }

                <form method="post" id="signup-form">
                    @Html.AntiForgeryToken()

                    <div style="margin-bottom:1.6rem;">
                        <label for="name" style="display:block;font-size:1.3rem;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-secondary);margin-bottom:0.6rem;">
                            Name
                        </label>
                        <input type="text" id="name" name="Name" value="@Model.Input.Name"
                               maxlength="191" placeholder="Jamie Larson (optional)"
                               style="width:100%;padding:1rem 1.4rem;border:1px solid var(--color-border);border-radius:6px;font-size:1.5rem;background:var(--color-bg);color:var(--color-text);" />
                    </div>

                    <div style="margin-bottom:1.6rem;">
                        <label for="email" style="display:block;font-size:1.3rem;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-secondary);margin-bottom:0.6rem;">
                            Email <span style="color:#dc3545;">*</span>
                        </label>
                        <input type="email" id="email" name="Email" value="@Model.Input.Email"
                               required maxlength="191" placeholder="you@example.com"
                               style="width:100%;padding:1rem 1.4rem;border:1px solid var(--color-border);border-radius:6px;font-size:1.5rem;background:var(--color-bg);color:var(--color-text);" />
                    </div>

                    @if (Model.AvailableNewsletters.Count > 0)
                    {
                        <fieldset style="border:none;padding:0;margin:0 0 2rem;">
                            <legend style="font-size:1.3rem;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-secondary);margin-bottom:0.8rem;">
                                Newsletters
                            </legend>
                            @foreach (var nl in Model.AvailableNewsletters)
                            {
                                <label style="display:flex;align-items:center;gap:0.8rem;margin-bottom:0.6rem;font-size:1.5rem;color:var(--color-text);cursor:pointer;">
                                    <input type="checkbox" name="NewsletterIds" value="@nl.Id"
                                           checked="@(nl.SubscribeOnSignup ? "checked" : null)"
                                           style="width:1.8rem;height:1.8rem;accent-color:var(--ghost-accent-color);" />
                                    @nl.Name
                                    @if (!string.IsNullOrEmpty(nl.Description))
                                    {
                                        <span style="color:var(--color-text-secondary);font-size:1.3rem;">— @nl.Description</span>
                                    }
                                </label>
                            }
                        </fieldset>
                    }

                    <button type="submit"
                            style="width:100%;padding:1.2rem;background:var(--ghost-accent-color);color:white;border:none;border-radius:6px;font-size:1.6rem;font-weight:600;cursor:pointer;transition:opacity 0.2s;">
                        Subscribe
                    </button>
                </form>

                <p style="text-align:center;margin-top:2rem;font-size:1.4rem;color:var(--color-text-secondary);">
                    Already have an account?
                    <a href="/signin/" style="color:var(--ghost-accent-color);font-weight:600;">Sign in</a>
                </p>
            }
        </div>
    </article>
</main>


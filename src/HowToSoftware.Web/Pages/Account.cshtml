@page "/account"
@model HowToSoftware.Web.Pages.AccountModel
@{
    ViewData["Title"] = "Your Account";
    ViewData["BodyClass"] = "account-page";
}

<main class="site-main">
    <article class="gh-article">
        <div class="gh-article-header gh-canvas" style="text-align:center;padding:6rem 0 3rem;">
            <h1 class="gh-article-title">Your Account</h1>
            <p class="gh-article-excerpt" style="margin-top:1rem;font-size:1.8rem;color:var(--color-text-secondary);">
                Manage your profile and newsletter preferences.
            </p>
        </div>

        <div class="gh-content gh-canvas" style="max-width:540px;margin:0 auto;padding-bottom:6rem;">
            @if (Model.SuccessMessage is not null)
            {
                <div style="background:var(--color-primary);color:white;padding:1.6rem 2rem;border-radius:8px;text-align:center;margin-bottom:2rem;font-size:1.5rem;">
                    @Model.SuccessMessage
                </div>
            }

            @if (Model.ErrorMessage is not null)
            {
                <div style="background:#dc3545;color:white;padding:1.2rem 2rem;border-radius:8px;text-align:center;margin-bottom:2rem;font-size:1.4rem;">
                    @Model.ErrorMessage
                </div>
            }

            <form method="post" id="account-form">
                @Html.AntiForgeryToken()

                @* ── Profile Section ── *@
                <section style="margin-bottom:3rem;">
                    <h2 style="font-size:2rem;font-weight:700;margin-bottom:2rem;padding-bottom:0.8rem;border-bottom:1px solid var(--color-border);">
                        Profile
                    </h2>

                    <div style="margin-bottom:1.6rem;">
                        <label for="email-display" style="display:block;font-size:1.3rem;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-secondary);margin-bottom:0.6rem;">
                            Email
                        </label>
                        <input type="email" id="email-display" value="@Model.CurrentMember.Email"
                               disabled readonly
                               style="width:100%;padding:1rem 1.4rem;border:1px solid var(--color-border);border-radius:6px;font-size:1.5rem;background:var(--color-bg);color:var(--color-text-secondary);opacity:0.7;cursor:not-allowed;" />
                        <span style="display:block;margin-top:0.4rem;font-size:1.2rem;color:var(--color-text-secondary);">
                            Your email address cannot be changed here.
                        </span>
                    </div>

                    <div style="margin-bottom:1.6rem;">
                        <label for="name" style="display:block;font-size:1.3rem;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-secondary);margin-bottom:0.6rem;">
                            Name
                        </label>
                        <input type="text" id="name" name="Input.Name" value="@Model.Input.Name"
                               maxlength="191" placeholder="Jamie Larson"
                               style="width:100%;padding:1rem 1.4rem;border:1px solid var(--color-border);border-radius:6px;font-size:1.5rem;background:var(--color-bg);color:var(--color-text);" />
                    </div>
                </section>

                @* ── Newsletter Subscriptions Section ── *@
                @if (Model.AvailableNewsletters.Count > 0)
                {
                    <section style="margin-bottom:3rem;">
                        <h2 style="font-size:2rem;font-weight:700;margin-bottom:2rem;padding-bottom:0.8rem;border-bottom:1px solid var(--color-border);">
                            Email Newsletters
                        </h2>
                        <p style="font-size:1.4rem;color:var(--color-text-secondary);margin-bottom:1.6rem;">
                            Choose which newsletters you'd like to receive.
                        </p>

                        @foreach (var nl in Model.AvailableNewsletters)
                        {
                            var isSubscribed = Model.CurrentSubscriptionIds.Contains(nl.Id);
                            <label style="display:flex;align-items:flex-start;gap:1rem;margin-bottom:1.2rem;font-size:1.5rem;color:var(--color-text);cursor:pointer;padding:1.2rem;border:1px solid var(--color-border);border-radius:8px;transition:border-color 0.2s;">
                                <input type="checkbox" name="SubscribedNewsletterIds" value="@nl.Id"
                                       checked="@(isSubscribed ? "checked" : null)"
                                       style="width:1.8rem;height:1.8rem;accent-color:var(--ghost-accent-color);margin-top:0.2rem;flex-shrink:0;" />
                                <span>
                                    <strong>@nl.Name</strong>
                                    @if (!string.IsNullOrEmpty(nl.Description))
                                    {
                                        <br />
                                        <span style="color:var(--color-text-secondary);font-size:1.3rem;">@nl.Description</span>
                                    }
                                </span>
                            </label>
                        }
                    </section>
                }

                @* ── Billing Section (Future) ── *@
                <section style="margin-bottom:3rem;">
                    <h2 style="font-size:2rem;font-weight:700;margin-bottom:2rem;padding-bottom:0.8rem;border-bottom:1px solid var(--color-border);">
                        Billing
                    </h2>
                    <div style="padding:2rem;border:1px dashed var(--color-border);border-radius:8px;text-align:center;">
                        <p style="font-size:1.5rem;color:var(--color-text-secondary);margin:0;">
                            You're on the <strong style="color:var(--color-text);">Free</strong> plan.
                        </p>
                        <p style="font-size:1.3rem;color:var(--color-text-secondary);margin-top:0.8rem;">
                            Paid subscriptions coming soon.
                        </p>
                    </div>
                </section>

                <button type="submit"
                        style="width:100%;padding:1.2rem;background:var(--ghost-accent-color);color:white;border:none;border-radius:6px;font-size:1.6rem;font-weight:600;cursor:pointer;transition:opacity 0.2s;">
                    Save settings
                </button>
            </form>

            @* ── Sign Out ── *@
            <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid var(--color-border);text-align:center;">
                <form method="post" asp-page-handler="SignOut">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            style="padding:0.8rem 2rem;background:transparent;color:var(--color-text-secondary);border:1px solid var(--color-border);border-radius:6px;font-size:1.4rem;cursor:pointer;transition:color 0.2s,border-color 0.2s;">
                        Sign out
                    </button>
                </form>
            </div>
        </div>
    </article>
</main>

